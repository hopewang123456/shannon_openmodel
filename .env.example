# Shannon Environment Configuration
# Copy this file to .env and fill in your credentials

# =============================================================================
# LLM Provider Selection
# =============================================================================
# Set to "openai" (default) or "anthropic"
# LLM_PROVIDER=openai

# =============================================================================
# OPTION 1: OpenAI-compatible (DeepSeek, OpenAI, OpenRouter, etc.)
# =============================================================================
# OPENAI_API_KEY=your-api-key-here
# OPENAI_BASE_URL=https://api.deepseek.com/v1

# =============================================================================
# OPTION 2: Anthropic API (direct or via DeepSeek's Anthropic endpoint)
# =============================================================================
# ANTHROPIC_API_KEY=your-api-key-here
# ANTHROPIC_BASE_URL=https://api.deepseek.com/anthropic

# =============================================================================
# Model Tier Config
# =============================================================================
# LLM_SMALL_MODEL=deepseek-chat
# LLM_MEDIUM_MODEL=deepseek-chat
# LLM_LARGE_MODEL=deepseek-chat
# LLM_MAX_TOKENS=64000

# =============================================================================
# OPTION 3 (DEPRECATED): AWS Bedrock
# Note: Bedrock support uses the Anthropic model tier env vars
# =============================================================================
# CLAUDE_CODE_USE_BEDROCK=1
# AWS_REGION=us-east-1
# AWS_BEARER_TOKEN_BEDROCK=your-bedrock-token
# ANTHROPIC_SMALL_MODEL=...
# ANTHROPIC_MEDIUM_MODEL=...
# ANTHROPIC_LARGE_MODEL=...

# =============================================================================
# OPTION 4 (DEPRECATED): Google Vertex AI
# =============================================================================
# CLAUDE_CODE_USE_VERTEX=1
# CLOUD_ML_REGION=us-east5
# ANTHROPIC_VERTEX_PROJECT_ID=your-project-id
# GOOGLE_APPLICATION_CREDENTIALS=/path/to/service-account.json
# ANTHROPIC_SMALL_MODEL=...
# ANTHROPIC_MEDIUM_MODEL=...
# ANTHROPIC_LARGE_MODEL=...
